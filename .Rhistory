library(pwr)
install.packages("pwr")
library(pwr)
pwr.r.test(n = 142, r= NULL, sig.level = 0.05, power = 0.8)
library(metafor)
# Replace these with your actual sample sizes
n1 <- 100  # Sample size for Study 1
n2 <- 120  # Sample size for Study 2
# Data
dat <- data.frame(
study = c("Study 1", "Study 2"),
r = c(0.43, 0.31),
n = c(n1, n2)
)
View(dat)
# Calculate effect sizes and variances
dat_es <- escalc(measure = "ZCOR", ri = r, ni = n, data = dat)
View(dat_es)
# Meta-analysis
res <- rma(yi, vi, data = dat_es, method = "REML")
# Combined effect size
combined_z <- res$b[1]
combined_r <- tanh(combined_z)
# Print result
print(paste("Combined r:", round(combined_r, 3)))
library(readr)
df <- read_csv("C:/Users/yashv/Downloads/metaware_meta_clean (1).csv")
View(df)
table(df$vig.1)
# packages
library(tidyverse)
# --- data ---------------------------------------------------------------
df <- tribble(
~label,                          ~r,    ~lo,   ~hi,
"Anderson & Bushman (2001)",     0.19,  0.15,  0.22,
"Anderson et al. (2004)",        0.16,  0.13,  0.19,
"Anderson et al. (2004)",        0.27,  0.24,  0.30,
"Ferguson (2007a)",              0.29,  0.11,  0.45,
"Ferguson (2007a)",              0.15,  0.06,  0.24,
"Ferguson (2007b)",              0.14,  0.08,  0.21,
"Ferguson & Kilburn (2009)",     0.08,  0.03,  0.13,
"Anderson et al. (2010)",        0.19,  0.18,  0.20,
"Greitemeyer & Mügge (2014)",    0.19,  0.16,  0.22,
"APA Task Force (2015)",         0.18,  0.10,  0.27,
"Hilgard et al. (2017)",         0.15,  0.10,  0.20,
"Hilgard et al. (2017)",         0.24,  0.19,  0.28,
"Ferguson et al. (2020)",        0.09,  0.07,  0.12
) |>
mutate(row = rev(row_number()))  # puts first entry at the top
# --- plot ---------------------------------------------------------------
ggplot(df, aes(x = r, y = row)) +
# 95% CI as a horizontal bar
geom_segment(aes(x = lo, xend = hi, y = row, yend = row), linewidth = 0.6) +
# point estimate as a square
geom_point(shape = 15, size = 2.8) +
# vertical reference line at r = 0
geom_vline(xintercept = 0, color = "grey60", linewidth = 0.3) +
# axis formatting
scale_y_continuous(
breaks = df$row,
labels = df$label,
expand = expansion(mult = c(0.02, 0.02))
) +
scale_x_continuous(name = "Pearson's r") +
labs(y = NULL) +
coord_cartesian(xlim = c(-0.05, 0.50)) +
theme_classic(base_size = 12) +
theme(
axis.ticks.y = element_blank(),
legend.position = "none"
)
# after your ggplot code, assign it:
p <- last_plot()   # or p <- <your ggplot(...) + ...>
# --- PDF (vector, embedded fonts via Cairo) ---
ggsave("forestplot.pdf",
plot = p,
device = cairo_pdf,       # from grDevices
width = 6, height = 4, units = "in",
bg = "white")
# --- SVG (best for Illustrator/Inkscape; fully editable) ---
# install.packages("svglite")  # if not installed
ggsave("forestplot.svg",
plot = p,
device = svglite::svglite,
width = 6, height = 4, units = "in",
bg = "white")
# --- EPS (for LaTeX or journals that want EPS) ---
ggsave("forestplot.eps",
plot = p,
device = cairo_ps,        # EPS via Cairo
width = 6, height = 4, units = "in",
bg = "white")
# --- SVG (best for Illustrator/Inkscape; fully editable) ---
# install.packages("svglite")  # if not installed
ggsave("vvg_mas.svg",
plot = p,
device = svglite::svglite,
width = 6, height = 4, units = "in",
bg = "white")
devtools::install_github("Y45HV1N/contrastanalysis", build_vignettes = TRUE)
vignette("tutorial", package = "contrastanalysis")
# 1. Prep the data: Group species and remove missing heights
sw_data <- starwars %>%
# Create our 3-level group
mutate(char_type = case_when(
species == "Human" ~ "Human",
species == "Droid" ~ "Droid",
TRUE ~ "Alien" # Groups Wookiees, Gungans, Twi'leks, etc. together
)) %>%
# Remove rows without height data
filter(!is.na(height)) %>%
# Convert to a factor
mutate(char_type = factor(char_type))
library(dplyr)
# 1. Prep the data: Group species and remove missing heights
sw_data <- starwars %>%
# Create our 3-level group
mutate(char_type = case_when(
species == "Human" ~ "Human",
species == "Droid" ~ "Droid",
TRUE ~ "Alien" # Groups Wookiees, Gungans, Twi'leks, etc. together
)) %>%
# Remove rows without height data
filter(!is.na(height)) %>%
# Convert to a factor
mutate(char_type = factor(char_type))
# Check our groups (Levels usually default to alphabetical: Alien, Droid, Human)
levels(sw_data$char_type)
table(sw_data$char_type) # Just to see our sample sizes
psych::describeBy(sw_data$height, group = sw_data$char_type)
library(dplyr)
# 1. Prep the data: Group species and remove missing heights
sw_data <- starwars %>%
# Create our 3-level group
mutate(char_type = case_when(
species == "Human" ~ "Human",
species == "Droid" ~ "Droid",
TRUE ~ "Alien" # Groups Wookiees, Gungans, Twi'leks, etc. together
)) %>%
# Remove rows without height data
filter(!is.na(height)) %>%
# Convert to a factor
mutate(char_type = factor(char_type))
# Check our groups (Levels usually default to alphabetical: Alien, Droid, Human)
levels(sw_data$char_type)
table(sw_data$char_type) # Just to see our sample sizes
psych::describeBy(sw_data$height, group = sw_data$char_type)
model_anova <- lm(height ~ char_type, data = sw_data)
aov(model_anova)
summary(aov(model_anova))
library(contrastanalysis)
contrast_analysis(
data       = sw_data,
dv         = "height",
conditions = "char_type",
hypothesis = c(Alien = 1, Droid = 0, Human = 1),  # example hypothesis
design     = "between",
delta      = 0.3
)
contrast_analysis(
data       = sw_data,
dv         = "height",
conditions = "char_type",
hypothesis = c(Alien = 1, Droid = 0, Human = 1),  # example hypothesis
design     = "between",
delta      = 0.3,
graph2 = TRUE
)
